	<parameter name="customerId" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.js.ic.ds" value="dataSources/custom"/>
		<property name="com.jaspersoft.studio.js.ic.label" value="Customer"/>
		<property name="com.jaspersoft.studio.js.ic.type" value="SINGLE_QUERY"/>
		<property name="com.jaspersoft.studio.js.ic.value" value="{&quot;query&quot;:&quot;select c.id, c.first_name || ' ' || c.last_name as name from customers c join orders o on o.customer_id = c.id group by c.id, c.first_name, c.last_name order by count(*) desc, c.last_name, c.first_name&quot;,&quot;language&quot;:&quot;sql&quot;,&quot;valueField&quot;:&quot;id&quot;,&quot;columns&quot;:[&quot;name&quot;]}"/>
	</parameter>
	<parameter name="status" class="java.util.ArrayList" nestedType="java.lang.String">
		<property name="com.jaspersoft.studio.js.ic.label" value="Status"/>
		<property name="com.jaspersoft.studio.js.ic.type" value="MULTI_QUERY"/>
		<property name="com.jaspersoft.studio.js.ic.value" value="{&quot;query&quot;:&quot;select distinct status as id, status as name from orders order by status&quot;,&quot;language&quot;:&quot;sql&quot;,&quot;valueField&quot;:&quot;id&quot;,&quot;columns&quot;:[&quot;name&quot;]}"/>
	</parameter>
	<parameter name="categoryId" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.js.ic.label" value="Category"/>
		<property name="com.jaspersoft.studio.js.ic.type" value="SINGLE_QUERY"/>
		<property name="com.jaspersoft.studio.js.ic.value" value="{&quot;query&quot;:&quot;select id, name from categories order by name&quot;,&quot;language&quot;:&quot;sql&quot;,&quot;valueField&quot;:&quot;id&quot;,&quot;columns&quot;:[&quot;name&quot;]}"/>
	</parameter>
	<parameter name="dateFrom" class="java.sql.Date">
		<property name="com.jaspersoft.studio.js.ic.label" value="Order Date From"/>
	</parameter>
	<parameter name="dateTo" class="java.sql.Date">
		<property name="com.jaspersoft.studio.js.ic.label" value="Order Date To"/>
	</parameter>
	<parameter name="minOrderTotal" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.js.ic.label" value="Minimum Order Total"/>
	</parameter>
	<parameter name="minItems" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.js.ic.label" value="Minimum Items"/>
	</parameter>
	<query language="sql"><![CDATA[SELECT
  os.order_id,
  os.order_date,
  os.status,
  os.customer_id,
  os.customer_name,
  os.region_name,
  os.country_name,
  os.city_name,
  os.order_total,
  oi_stats.item_count,
  CASE WHEN oi_stats.item_count = 0 THEN 0 ELSE os.order_total / oi_stats.item_count END AS avg_item_price
FROM v_order_summary os
JOIN (
  SELECT oi.order_id, SUM(oi.quantity) AS item_count
  FROM order_items oi
  GROUP BY oi.order_id
) oi_stats ON oi_stats.order_id = os.order_id
WHERE
  ($P{customerId} IS NULL OR os.customer_id = $P{customerId})
  AND $X{IN, os.status, status}
  AND ($P{dateFrom} IS NULL OR os.order_date >= $P{dateFrom})
  AND ($P{dateTo} IS NULL OR os.order_date <= $P{dateTo})
  AND ($P{minOrderTotal} IS NULL OR os.order_total >= $P{minOrderTotal})
  AND ($P{minItems} IS NULL OR oi_stats.item_count >= $P{minItems})
  AND ($P{categoryId} IS NULL OR EXISTS (
    SELECT 1
    FROM order_items oi
    JOIN products p ON p.id = oi.product_id
    WHERE oi.order_id = os.order_id AND p.category_id = $P{categoryId}
  ))
ORDER BY os.order_date DESC, os.order_id DESC]]></query>
