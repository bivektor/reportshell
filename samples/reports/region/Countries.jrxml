		<property name="com.jaspersoft.studio.js.ic.label" value="Region"/>
		<property name="com.jaspersoft.studio.js.ic.type" value="SINGLE_QUERY"/>
		<property name="com.jaspersoft.studio.js.ic.value" value="{&quot;query&quot;:&quot;SELECT * from \&quot;REGIONS\&quot; order by name&quot;,&quot;language&quot;:&quot;sql&quot;,&quot;valueField&quot;:&quot;id&quot;,&quot;columns&quot;:[&quot;name&quot;]}"/>
	</parameter>
	<query language="SQL"><![CDATA[ select c.* , r.name as region
 from "COUNTRIES" c
 join "REGIONS" as r on c.region_id = r.id
 where ( $P{region} IS NULL OR c.region_id = $P{region} )
  order by name]]></query>
