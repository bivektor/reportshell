		<property name="com.jaspersoft.studio.js.ic.label" value="Created Before"/>
	</parameter>
	<parameter name="regions" class="java.util.ArrayList" nestedType="java.lang.Integer">
		<property name="com.jaspersoft.studio.js.ic.label" value="Region"/>
		<property name="com.jaspersoft.studio.js.ic.type" value="MULTI_QUERY"/>
		<property name="com.jaspersoft.studio.js.ic.value" value="{&quot;query&quot;:&quot;select * from REGIONS order by name&quot;,&quot;language&quot;:&quot;sql&quot;,&quot;valueField&quot;:&quot;id&quot;,&quot;columns&quot;:[&quot;name&quot;]}"/>
	</parameter>
	<parameter name="countries" class="java.util.ArrayList" nestedType="java.lang.Integer">
		<description><![CDATA[Country list]]></description>
		<property name="com.jaspersoft.studio.js.ic.label" value="Country"/>
		<property name="com.jaspersoft.studio.js.ic.type" value="MULTI_QUERY"/>
		<property name="com.jaspersoft.studio.js.ic.value" value="{&quot;query&quot;:&quot;select co.*, r.name as regionName \nfrom COUNTRIES as co\n inner join REGIONS as r on r.id = co.region_id \n where $X{IN, co.region_id, regions}\norder by co.name, r.name&quot;,&quot;language&quot;:&quot;sql&quot;,&quot;valueField&quot;:&quot;id&quot;,&quot;columns&quot;:[&quot;name&quot;,&quot;regionName&quot;]}"/>
		<property name="com.bivektor.reportshell.ic.required" value="false"/>
	</parameter>
	<parameter name="cities" class="java.util.ArrayList" nestedType="java.lang.Integer">
		<property name="com.jaspersoft.studio.js.ic.label" value="City"/>
		<property name="com.jaspersoft.studio.js.ic.type" value="MULTI_QUERY"/>
		<property name="com.jaspersoft.studio.js.ic.value" value="{&quot;query&quot;:&quot;SELECT c.*, co.name as countryName from CITIES c\n inner join COUNTRIES as co on c.country_id = co.id\ninner join REGIONS r on r.id = co.region_id\n where $X{IN, c.country_id, countries} AND $X{IN, r.id, regions}\norder by c.name, co.name&quot;,&quot;language&quot;:&quot;sql&quot;,&quot;valueField&quot;:&quot;id&quot;,&quot;columns&quot;:[&quot;name&quot;,&quot;countryName&quot;]}"/>
		<property name="com.jaspersoft.studio.js.ic.ds" value=""/>
	</parameter>
	<parameter name="minPurchaseAmount" class="java.math.BigDecimal">
		<description><![CDATA[Minimum purchase amount]]></description>
		<property name="com.jaspersoft.studio.js.ic.label" value="Minimum Purchase Amount"/>
	</parameter>
	<parameter name="minOrders" class="java.lang.Long">
		<description><![CDATA[Minimum number of orders]]></description>
		<property name="com.jaspersoft.studio.js.ic.label" value="Minimum number of Orders"/>
	</parameter>
	<query language="sql"><![CDATA[SELECT c.*, ct."NAME" as CITY_NAME, co."NAME" as COUNTRY_NAME, COALESCE(pa.total_purchase_amount, 0) as TOTAL_PURCHASE_AMOUNT
FROM "CUSTOMERS" AS c
LEFT JOIN "CITIES" as ct on c.city_id = ct.id
LEFT JOIN "COUNTRIES" as co on ct.country_id = co.id
LEFT JOIN (
    SELECT o.customer_id, SUM(oi.quantity * oi.unit_price) as total_purchase_amount
    FROM "ORDERS" o 
    JOIN "ORDER_ITEMS" oi ON oi.order_id = o.id 
    WHERE o.status in ('PAID', 'SHIPPED')
    GROUP BY o.customer_id
) pa ON pa.customer_id = c.id
WHERE 
	  ( 
	 $X{IN,ct."ID",cities} and
	  $X{IN,co."ID",countries} and
	  $X{IN,co."REGION_ID",regions} and
	 $X{[GREATER, c.created_at, createdAfter} and
	 $X{LESS], c.created_at, createdBefore} and
	 $X{[GREATER, (SELECT COUNT(*) FROM "ORDERS" o WHERE o.customer_id = c.id), minOrders} and
	 $X{[GREATER, TOTAL_PURCHASE_AMOUNT, minPurchaseAmount}
	 )
	 ORDER BY c.FIRST_NAME]]></query>
